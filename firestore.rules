rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Hardened Global Helper Functions ---
    
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Simplifies request state checks
    function incoming() {
      return request.resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Entity Specific Shape Validators ---

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('plan' in data) || (data.plan == 'free' || data.plan == 'basic' || data.plan == 'profesional' || data.plan == 'premium')) &&
             (!('trial' in data) || (data.trial is bool)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 40)) &&
             (!('lastLogin' in data) || (data.lastLogin is string && data.lastLogin.size() <= 40));
    }

    function isValidBusiness(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.niche is string && data.niche.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             (!('targetAudience' in data) || (data.targetAudience is string && data.targetAudience.size() <= 2000)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 40));
    }

    function isValidStrategy(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.summary is string && data.summary.size() <= 60000 &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 40));
    }

    function isValidCalendarItem(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.copy is string && data.copy.size() <= 40000 &&
             data.scheduledDate is string && data.scheduledDate.size() <= 128 &&
             (!('status' in data) || (
               data.status == 'draft' || data.status == 'scheduled' || data.status == 'published' ||
               data.status == 'Borrador' || data.status == 'Pendiente de aprobación' ||
               data.status == 'Aprobado' || data.status == 'Programado' ||
               data.status == 'Publicado' || data.status == 'Cancelado' ||
               data.status == 'Vencido'
             )) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 40));
    }

    function isValidUploadedMaterial(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.name is string && data.name.size() <= 500 &&
             (data.type == 'image' || data.type == 'video') &&
             data.url is string && data.url.size() <= 2000 &&
             (!('size' in data) || (data.size is int || data.size is float)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 40));
    }

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Subscriptions Collection Routing ---
    match /subscriptions/{userId} {
      allow read, write: if true;
    }

    // --- Payment Submissions Collection Routing ---
    match /payment_submissions/{submissionId} {
      allow read, write: if true;
    }

    // --- User-Scoped Routes ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());

      match /businesses/{businessId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(businessId) && isValidBusiness(incoming());
        allow delete: if isOwner(userId) && isValidId(businessId);
      }

      match /strategies/{strategyId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(strategyId) && isValidStrategy(incoming());
        allow delete: if isOwner(userId) && isValidId(strategyId);
      }

      match /calendar/{calendarId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(calendarId) && isValidCalendarItem(incoming());
        allow delete: if isOwner(userId) && isValidId(calendarId);
      }

      match /materials/{materialId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(materialId) && isValidUploadedMaterial(incoming());
        allow delete: if isOwner(userId) && isValidId(materialId);
      }
    }
  }
}
